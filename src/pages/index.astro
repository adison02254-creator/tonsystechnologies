---
// Tonsys Homebase - Dual Persona (Final Touch)
---

<html lang="th">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TONSYS | The Hybrid Identity</title>
    <link rel="icon" type="image/png" href="/tonsys-logo-only.png" />
    <link href="https://fonts.googleapis.com/css2?family=Itim&family=Kanit:wght@300;400;600;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --tech-green: #5b5555;
            --furry-pink: #ffffff;
            --bg-dark: #0a0a0a;
            --bg-gradient: linear-gradient(-45deg, #050a15, #1e3c72, #ad1818, #16213e);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Kanit', sans-serif; }
        
        /* === ✅ จุดที่ 1: ซ่อนเมาส์ระบบ === */
        /* เพิ่มคำสั่งนี้เพื่อซ่อน cursor ปกติของ Windows/Browser ทิ้งไป */
        body { 
            background: var(--bg-gradient);
            background-size: 400% 400%;
            animation: gradientBG 15s ease infinite;
            color: #fff;
            min-height: 100vh;
            overflow-x: hidden;
        }

        @keyframes gradientBG { 
            0% { background-position: 0% 50%; } 
            50% { background-position: 100% 50%; } 
            100% { background-position: 0% 50%; } 
        }
        
        /* มั่นใจว่า Link ต่างๆ ก็ไม่โชว์เมาส์ปกติ */
        a, button, [role="button"] { cursor: none; }

        /* [1] LOADING SCREEN - CUTE BOOT UP */
        #loader {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: #000; z-index: 10000; display: flex;
            flex-direction: column; justify-content: center; align-items: center;
            transition: opacity 0.8s ease;
        }
        /* ปรับ Font ให้น่ารักขึ้น */
        .boot-text { 
            font-family: 'Itim', cursive; 
            color: var(--furry-pink); 
            font-size: 1.2rem; 
            text-align: center; 
            line-height: 1.5;
        }
        .paw-loader { font-size: 4rem; margin-bottom: 20px; animation: bounce 1s infinite; }
        @keyframes bounce { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-20px); } }

        /* === ✅ จุดที่ 2: วงกลม Cursor (เหมือนเดิม) === */
        #cursor { 
            position: fixed; 
            width: 12px; 
            height: 12px; 
            border: 2px solid var(--tech-green); 
            border-radius: 50%; 
            pointer-events: none; 
            z-index: 9999; 
            transition: 0.1s; 
            background-color: var(--tech-green); /* เพิ่มสีข้างในให้ดูชัดขึ้นเหมือนอันเก่า */
            
        }
        
        nav { padding: 20px 5%; background-color: rgba(20,20,20,0.8); backdrop-filter: blur(10px); border-bottom: 1px solid #333; display: flex; justify-content: space-between; align-items: center; position: sticky; top: 0; z-index: 1000; }

        #particles-js { position: fixed; width: 100%; height: 100%; top: 0; left: 0; z-index: 0; }

        .hero {
            height: 80vh; display: flex; flex-direction: column; align-items: center; justify-content: center;
            position: relative; overflow: hidden; text-align: center;
        }
        .hero-title { font-size: clamp(3rem, 12vw, 8rem); font-weight: 800; line-height: 1; }
        /* แก้ในส่วน <style> ของมึง */
        .tech-side { color: #e0e0e0; text-shadow: 0 0 10px rgba(255, 255, 255, 0.2); } /* สีเทาขาวสะอาดๆ */
        .er-side { color: #ff3c3c; text-shadow: 0 0 20px rgba(255, 0, 0, 0.6); }      /* แดงสว่างๆ ขยี้คำว่า ERROR */
        .furry-side { color: #00f2ff; text-shadow: 0 0 20px rgba(0, 242, 255, 0.6); } /* ฟ้า Cyan แบบ NixOS */
        .co-side { color: #00ff26; text-shadow: 0 0 20px rgba(30, 255, 0, 0.6); }


        /* คำอธิบายเว็บที่ปรับปรุงใหม่ */
        .intro { 
            max-width: 700px; 
            margin: 0 auto; 
            padding: 0 20px;
            text-align: center; 
        }
        .intro p { 
            font-size: 1.1rem; 
            color: #fff; 
            font-family: 'JetBrains Mono', monospace;
            background: rgba(95, 95, 95, 0.178);
            padding: 15px;
            border-radius: 8px;
            border: 1px solid #ffffff;
        }

        /* === ✅ จุดที่ 3: เตรียมการ์ดให้เอียงได้ (Perspective) === */
        /* --- แก้ไขจุดนี้ --- */
        .archive-container { 
            padding: 20px 5%; /* ลด Padding บน-ล่าง จาก 60px เหลือ 20px */
            max-width: 1100px; 
            margin: 0 auto;
            perspective: 1000px;
        }

        
        /* === ✅ จุดที่ 4: ปรับแต่ง Project Item สำหรับ Animation === */
        /* --- แก้ไขจุดนี้ --- */
        .project-item {
            background: rgba(87, 87, 87, 0.342);
            border: 1px solid #333;
            border-radius: 20px;
            margin-bottom: 12px; /* ลดจาก 25px เหลือ 12px เพื่อให้ดูชิดกันมากขึ้น */
            overflow: hidden;
            backdrop-filter: blur(15px);
            transition: transform 0.1s ease, box-shadow 0.3s ease;
            transform-style: preserve-3d;
            will-change: transform;
        }


        .project-header { padding: 30px; display: flex; justify-content: space-between; align-items: center; cursor: none; } /* เปลี่ยน cursor:none ตรงนี้ด้วย */
        .project-header h3 { font-size: 1.6rem; font-weight: 700; color: #fff; }
        .arrow { font-size: 1.2rem; color: var(--tech-green); transition: 0.4s; }

        .project-content { max-height: 0; overflow: hidden; transition: max-height 0.8s ease-in-out; }
        .content-inner { padding: 40px; display: flex; flex-wrap: wrap; gap: 30px; border-top: 1px solid #222; }
        
        .project-image { flex: 1; min-width: 280px; height: 300px; background: #222; border-radius: 15px; display: flex; align-items: center; justify-content: center; border: 1px solid #444; }
        .project-info { flex: 1.5; min-width: 280px; }
        .project-info h4 { color: #fff; margin-bottom: 10px; font-size: 1.4rem; }
        .project-info p { line-height: 1.7; opacity: 0.8; margin-bottom: 15px; }

        /* === ✅ จุดที่ 5: เรืองแสงเวลา Hover === */
        .project-item:hover { 
            border-color: var(--tech-green); 
            box-shadow: 0 0 25px rgb(255, 255, 255); /* แสงสีเขียวอ่อนๆ เวลาเมาส์ชี้ */
        }

        /* เมื่อกดใช้งาน */
        .project-item.active { border-color: var(--furry-pink); box-shadow: 0 0 30px rgba(255,105,180,0.3); } /* ถ้า active ให้เรืองแสงสีชมพูแทน */
        .project-item.active .project-content { max-height: 1500px; }
        .project-item.active .arrow { transform: rotate(180deg); color: var(--furry-pink); }
 
        .logo { font-weight: 800; color: #ffffff; }
        .status { 
            font-size: 0.8rem; 
            font-family: 'JetBrains Mono'; 
            color: #fff; 
        }

        /* [5] FOOTER - THE GUARDIAN DATA */
        .footer-base {
            background-color: #121212; /* สีเทาเข้มเกือบดำตามรูป */
            padding: 40px 5%;
            text-align: center;
            border-top: 1px solid #333;
            margin-top: 50px;
            /* ระบบซ่อน: ตอนแรกจะจางๆ และกดไม่ได้ */
            /* opacity: 0; 
            filter: blur(5px);
            pointer-events: none; 
            transition: 0.8s all ease; */
        }

        /* เมื่อระบบถูกปลดล็อก (มึงค่อยใช้ JS มาแอด class 'unlocked' ทีหลัง) */
        .footer-links {
            display: flex;
            justify-content: center;
            gap: 30px;
            margin-bottom: 25px;
            flex-wrap: wrap;
        }

        .footer-links a {
            color: #888;
            text-decoration: none;
            font-size: 0.9rem;
            transition: 0.3s;
            cursor: none; /* ใช้เคอร์เซอร์เขียวของมึง */
        }

        .footer-links a:hover {
            color: var(--tech-green);
            text-shadow: 0 0 10px var(--tech-green);
        }

        .social-icons {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-bottom: 20px;
            font-size: 1.5rem;
        }

        .social-icons a { color: #fff; opacity: 0.8; transition: 0.3s; }
        .social-icons a:hover { color: var(--furry-pink); transform: translateY(-5px); }

        .copyright {
            color: #555;
            font-size: 0.8rem;
            font-family: 'JetBrains Mono', monospace;
            letter-spacing: 1px;
        }

        .contact-section {
            text-align: center;
            z-index: 1;
            position: relative;
            background: rgba(87, 87, 87, 0.342);
            border: 1px solid #333;
            display: flex;
            flex-direction: column; /* ✅ เพิ่มอันนี้: ให้ของข้างในเรียงลงมาเวลาจอแคบ */
            place-items: center;
            border-radius: 20px;
            margin-bottom: 25px;
    
            /* ❌ ลบของเก่า: width: 650px; height: 350px; */
    
            /* ✅ ใส่ของใหม่: */
            width: 90%;            /* ให้กว้าง 90% ของหน้าจอเสมอ (จะได้มีขอบเหลือนิดนึง) */
            max-width: 650px;      /* แต่ห้ามกว้างเกิน 650px (เวลาเปิดในคอมจะได้ไม่ใหญ่ไป) */
            min-height: 300px;     /* ใช้ min-height แทน เพื่อให้มันยืดความสูงได้ถ้าของข้างในเยอะ */
            padding: 40px 20px;    /* เพิ่มระยะห่างข้างในกล่อง จะได้ไม่เบียดขอบ */
    
            margin: 20px auto;     /* จัดกลางเหมือนเดิม */
        }


        .social-links { 
            display: flex; 
            justify-content: center; 
            gap: 20px; 
            margin-top: 30px; 
            flex-wrap: wrap; 
        }

        .social-item {
            padding: 15px 30px; border-radius: 50px; background: rgba(255,255,255,0.1);
            color: white; text-decoration: none; border: 1px solid var(--glass-border);
            transition: 0.3s; font-weight: 600;
        }
        .social-item:hover {
            background: var(--accent-blue); border-color: var(--accent-blue);
            transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,210,255,0.3);
        }

        footer { padding: 40px; text-align: center; opacity: 0.5; font-size: 0.8rem; }

        @media (max-width: 768px) { #cursor { display: none; } * { cursor: auto; } }
    </style>
</head>
<body>

    <div id="cursor"></div>

    <div id="loader">
        <div class="paw-loader">🐾</div>
        <div class="boot-text" id="bootText">
            เตรียมระบบ...
        </div>
    </div>

    <nav>
        <div class="logo">TONSYS_HOMEBASE</div>
        <div class="status">STATUS: CUTE_BUT_DEADLY</div>
    </nav>

    <div class="split-bg"></div>

    <main>
        <section class="hero">
            <h1 class="hero-title">
                <span class="tech-side">REALITY IS </span>
                <span class="er-side">ERROR</span>
                <span class="tech-side">PRONE</span><br>
                <span class="co-side">CODE</span>
                <span class="furry-side"> IS PERFECT</span>
            </h1>
            <div class="intro">
                <p> Welcome dev </p>
            </div>
        </section>

        <section class="archive-container">
            <div class="project-item">
                <div class="project-header">
                    <h3>01. CSG-X CERBERUS</h3>
                    <div class="arrow">▼</div>
                </div>
                <div class="project-content">
                    <div class="content-inner">
                        <div class="project-image">
                            <!-- <img src="/tonsys-logo-only.png" alt="CSG-X CERBERUS "width="300" height="200"> -->
                            <p>ไม่มีรูปภาพภาพ</p>
                        </div>
                        <div class="project-info">
                            <h4>The Security Guardian</h4>
                            <p>นี่คือโปรเจกต์ความปลอดภัยที่แข็งแกร่ง(ไม่ที่สุด)  มาพร้อมกับระบบตรวจสอบหลายขั้น และ สามารถรันได้บน NixOS และ หลายๆระบบปฎิบัติการ</p>
                            <p>
                                ​🏗️ 1. สถาปัตยกรรมระบบ (The 3-Node Structure) <br>
                                ​ผมสรุปโครงสร้างการตัดต่อข้อมูลเป็น 3 ส่วน <br>
                                เพื่อความปลอดภัยระดับองค์กร ดังนี้ครับ: <br>
                                ​เครื่องปลายทาง (Employee Endpoint): พื้นที่ทำงานที่ต้องมีโปรแกรมเฉพาะฝังอยู่เพื่อตรวจสอบไฟล์และป้องกันภัยคุกคามเบื้องต้น​เครื่อง <br>
                                ตัวกลาง (The Mediator): สมองกลส่วนกลางที่คอยตัดสินใจ วิเคราะห์พฤติกรรม และเช็คสิทธิ์การเข้าถึงแทนเซิร์ฟเวอร์ เพื่อเป็นด่านหน้าในการกรองข้อมูล <br>
                                ​สถานีข้อมูลปิด (Isolated Data Station): จุดเก็บข้อมูลสูงสุดที่จะรับข้อมูลผ่าน "ท่อปลอดภัย" จากเครื่องตัวกลางเท่านั้น และพร้อมตัดการเชื่อมต่อทันทีหากเกิดเหตุฉุกเฉิน​ <br>
                                📦 2. ระบบไฟล์นิรภัย (.cgsx)​สรุปกลไกพิเศษของไฟล์งานในระบบที่ถูกออกแบบมาให้ "ย้ายได้แต่เปิดไม่ได้" หากผิดเงื่อนไข: <br>
                                กลไกไฟล์ตัวประกัน: ภายในหนึ่งไฟล์ประกอบด้วยไฟล์งานและ "ไฟล์เพื่อน" ที่ต้องอยู่คู่กันเสมอ<br>
                                ​การป้องกันการคัดลอก: หากไฟล์งานถูกดึงออกไปโดยไม่มีไฟล์เพื่อนตามมา ระบบจะปฏิเสธการเข้าถึงข้อมูลทันที​<br>
                                ความสมบูรณ์ของ Seed: มีการใช้รหัสเฉพาะและลายเซ็นดิจิทัลกำกับ หากมีการดัดแปลงเพียงเล็กน้อย ไฟล์จะถูกล็อกหรือเสียหายทันทีเพื่อป้องกันการเจาะข้อมูล
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <section class="contact-section" id="contact" >
        <div class="contact-card">
            <h2 style="font-size: 2.5rem; margin-bottom: 10px;">GET IN TOUCH</h2>
            <p style="opacity: 0.8;">สนใจร่วมงานหรือสอบถามรายละเอียดโปรเจกต์ ติดต่อได้เลยครับ</p>
            
            <div class="social-links">
                <a href="https://www.facebook.com/Tonsonfurry" class="social-item nav-link">Facebook</a>
                <a href="https://github.com/adison02254-creator" class="social-item nav-link">GitHub</a>
                <a href="https://discord.com/channels/@furry_ton" class="social-item nav-link">Discord</a>
                <a href="mailto:contact@tonsys.com" class="social-item nav-link" style="background:#8ba2ff8a; color: #000;">Email Me</a>
            </div>
            
            <p style="margin-top: 20px; font-size: 0.9rem; opacity: 0.6;">พร้อมตอบกลับภายใน 24 ชั่วโมง :3</p>
        </div>
    </section>

    <footer class="footer-base" id="mainFooter">
        <div class="social-icons">
            <a href="#"><i class="fab fa-facebook"></i> f</a>
            <a href="#"><i class="fab fa-instagram"></i> i</a>
            <a href="#"><i class="fab fa-x-twitter"></i> x</a>
        </div>

        <div class="footer-links">
            <a href="#">เกี่ยวกับเรา</a>
            <a href="#">นโยบายความเป็นส่วนตัว (แบบปั่นๆ)</a>
            <a href="#">ติดต่อเรา</a>
        </div>

        <div class="copyright">
            © TONSYS HOMEBASE 2026 | ALL RIGHTS RESERVED BY ADISON
        </div>
    </footer>
    

    <script>
        const cursor = document.getElementById('cursor');
        // แก้ไข: เพิ่ม function เคลื่อนที่เมาส์ให้ลื่นขึ้น
        document.addEventListener('mousemove', e => {
            if (cursor) {
                cursor.style.left = e.clientX + 'px';
                cursor.style.top = e.clientY + 'px';
            }
        });

        // ข้อความหน้าโหลดแบบนุ่มฟู (เหมือนเดิมเป๊ะ กูแค่ลบคำอธิบายที่มึงขี้เกียจดูออก)
        const lines = [
            "กำลังหาขนมให้ระบบ... 🍪",
            "จัดระเบียบแป๊บนึง...",
            "กำลังออนไลน์...",
            "READY!"
        ];
        let i = 0;
        const bootText = document.getElementById('bootText');
        const interval = setInterval(() => {
            if(i < lines.length) {
                if (bootText) {
                    bootText.innerHTML += `<br>${lines[i]}`;
                }
                i++;
            } else {
                clearInterval(interval);
                setTimeout(() => {
                    const l = document.getElementById('loader');
                    if (l) {
                        l.style.opacity = '0';
                        setTimeout(() => l.style.display = 'none', 800);
                    }
                }, 1200);
            }
        }, 800);

        // ระบบ Accordion (เหมือนเดิม)
        document.querySelectorAll('.project-header').forEach(header => {
            header.addEventListener('click', () => {
                if (header.parentElement) {
                    header.parentElement.classList.toggle('active');
                }
            });
        });

        // === ✅ จุดที่ 6: Logic การเอียงการ์ดตามเมาส์ (Tilt Effect) ===
        // กูทำแบบง่ายๆ มาให้ มึงไม่ต้องเข้าใจโค้ดลึกก็ได้ แค่รู้ว่ามันใช้คณิตศาสตร์นิดหน่อยเพื่อหาตำแหน่งเมาส์เมื่อเทียบกับการ์ด
        const cards = document.querySelectorAll<HTMLElement>('.project-item');

        cards.forEach(card => {
            // เมื่อเมาส์เคลื่อนที่บนการ์ด
            card.addEventListener('mousemove', (e: MouseEvent) => {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left; // ตำแหน่ง X ของเมาส์ในตัวการ์ด
                const y = e.clientY - rect.top;  // ตำแหน่ง Y ของเมาส์ในตัวการ์ด
                const width = rect.width;
                const height = rect.height;

                // คำนวณเปอร์เซ็นต์ (กลางคือ 0, ขอบคือ -1 หรือ 1)
                const percentX = (x / width) * 2 - 1;
                const percentY = (y / height) * 2 - 1;

                // ตั้งค่าความแรงของการเอียง (มึงปรับเลข 500 หรือ 15 ตรงนี้ได้ตามใจชอบ)
                const tiltX = percentY * -15; // เอียงขึ้นลง
                const tiltY = percentX * 15;  // เอียงซ้ายขวา

                // ใช้ CSS transform เพื่อเอียงตัวการ์ด
                card.style.transform = `perspective(1000px) rotateX(${tiltX}deg) rotateY(${tiltY}deg) scale(1.02)`; // scale(1.02) เพื่อให้การ์ดขยายขึ้นนิดนึงเวลา hover
            });

            // เมื่อเมาส์ออกจากตัวการ์ด
            card.addEventListener('mouseleave', () => {
                // คืนค่า transform ทั้งหมดกลับเป็นปกติ
                card.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg) scale(1)';
            });
        });
    </script>
</body>
</html>